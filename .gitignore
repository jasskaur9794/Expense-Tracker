# ==========================================
# Expensify - Unified MERN Stack Git Ignore
# ==========================================

# Dependency Directories
node_modules/
backend/node_modules/
frontend/node_modules/

# Local Environment / Secrets (CRITICAL SECURITY)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
frontend/.env

# Production Builds & Compilation Artifacts
dist/
dist-ssr/
build/
frontend/dist/
frontend/dist-ssr/

# User Uploaded Static Files (Profile Avatars)
backend/uploads/avatars/*
!backend/uploads/avatars/.gitkeep
backend/uploads/receipts/*
!backend/uploads/receipts/.gitkeep

# System & OS Specific Metadata
.DS_Store
.DS_Store?
ehthumbs.db
Thumbs.db

# Editor Configurations & Temporary Files
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.project
.classpath
.settings/

# Diagnostic Logs & Debug Traces
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
