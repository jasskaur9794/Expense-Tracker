{
  "name": "expense-tracker-monorepo",
  "version": "1.0.0",
  "description": "MERN Expense Tracker Monorepo",
  "main": "backend/server.js",
  "scripts": {
    "install-backend": "npm install --prefix backend",
    "install-frontend": "npm install --prefix frontend --include=dev",
    "build-frontend": "npm run build --prefix frontend",
    "build": "npm run install-backend && npm run install-frontend && npm run build-frontend",
    "start": "node backend/server.js"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
